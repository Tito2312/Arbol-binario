{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["java"]
    },
    "buildCommand": "javac -d out src/*.java"
  },
  "deploy": {
    "startCommand": "java -cp out Main",
    "restartPolicyType": "ON_FAILURE"
  }
}